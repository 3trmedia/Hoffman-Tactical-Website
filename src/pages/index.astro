---
import Layout from '../layouts/Layout.astro';

const BASE = 'https://hoffmantactical.com/wp-content/uploads';

const products = [
  {
    name: 'SL-15 Lower Kit',
    price: '$89.00',
    img: `${BASE}/2023/12/SL15RK-Cover-scaled.jpg`,
    href: '/shop',
  },
  {
    name: 'SL-9 Ready Kit',
    price: '$74.00',
    img: `${BASE}/2024/02/SL9-RK-Cover-scaled.jpg`,
    href: '/shop',
  },
  {
    name: 'SL-308 Kit',
    price: '$94.00',
    img: `${BASE}/2025/01/SL-308-Product-Cover-scaled.jpg`,
    href: '/shop',
  },
  {
    name: 'Trigger Kicker',
    price: '$43.00',
    img: `${BASE}/2026/05/Trigger-Kicker-Product-Cover-scaled.jpg`,
    href: '/shop',
  },
  {
    name: 'SL-308 Combo Kit',
    price: '$149.00',
    img: `${BASE}/2025/01/SL-308-Combo-Product-Cover-scaled.jpg`,
    href: '/shop',
  },
  {
    name: 'SL-9 Complete Build',
    price: '$119.00',
    img: `${BASE}/2024/02/SL9-CB-Cover-scaled.jpg`,
    href: '/shop',
  },
];

const tiles = [
  {
    label: 'Designs',
    badge: 'Always free.',
    desc: 'Every design we release, at no cost.',
    href: '/files',
    img: `${BASE}/2024/04/Rendering-scaled.jpg`,
  },
  {
    label: 'Learn',
    badge: null,
    desc: 'Guides for printing, sourcing, and building.',
    href: '/guides',
    img: `${BASE}/2025/03/Creep-Test-in-Progress.jpg`,
  },
  {
    label: 'Guides',
    badge: null,
    desc: 'Build logs, breakdowns, and field notes.',
    href: '/guides',
    img: `${BASE}/2025/03/Ounce-inside-scaled.jpg`,
  },
  {
    label: 'Forum',
    badge: null,
    desc: 'Community questions and project threads.',
    href: 'https://forum.hoffmantactical.com',
    img: `${BASE}/2025/03/Forum-Home_framed.jpg`,
  },
];
---

<Layout title="Hoffman Tactical -- Build It Yourself" description="Free 3D-printable weapon system designs and build kits. Decentralized manufacturing.">

  <!-- HERO -->
  <section class="relative min-h-[88vh] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="https://hoffmantactical.com/wp-content/uploads/2025/03/Baby-Orca-Banner-scaled.jpg"
        alt="ORCA-15 build"
        class="w-full h-full object-cover object-center"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-[#0d0d0d] via-[#0d0d0d]/60 to-transparent"></div>
      <div class="absolute inset-0 bg-gradient-to-r from-[#0d0d0d]/70 via-transparent to-transparent"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 pt-32 w-full">
      <div class="max-w-xl">
        <p class="section-label mb-4">Hoffman Tactical</p>
        <h1 class="font-dm font-extrabold text-6xl sm:text-7xl lg:text-8xl text-ht-text leading-none tracking-tight mb-5">
          Build It<br />Yourself.
        </h1>
        <p class="text-ht-text/80 text-xl font-medium mb-8 leading-relaxed">
          Free designs. Real kits. Decentralized manufacturing.
        </p>
        <div class="flex flex-wrap gap-3">
          <a href="/shop" class="btn-primary">Shop Kits</a>
          <a href="/files" class="btn-ghost">Free Designs</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURE STRIP -->
  <div class="bg-ht-surface border-b border-ht-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-ht-border">
        {[
          { title: 'Designs Always Free', body: 'Every weapon system we design is released at no cost.' },
          { title: 'Kits Are a Convenience', body: 'All hardware can be sourced independently. Kits save time.' },
          { title: 'Detailed Documentation', body: 'Every design ships with full assembly and sourcing guides.' },
        ].map(f => (
          <div class="px-8 py-7">
            <p class="text-ht-accent text-xs font-bold uppercase tracking-widest mb-1.5">{f.title}</p>
            <p class="text-ht-muted text-sm leading-relaxed">{f.body}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- FLAGSHIP PRODUCT -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="overflow-hidden bg-ht-surface border border-ht-border">
        <img
          src="https://hoffmantactical.com/wp-content/uploads/2023/12/SL15RK-Plate-Group-scaled.jpg"
          alt="SL-15 Lower Kit hardware"
          class="w-full h-80 lg:h-[480px] object-cover object-center hover:scale-105 transition-transform duration-700"
        />
      </div>
      <div>
        <p class="section-label mb-3">Featured Kit</p>
        <h2 class="font-dm font-extrabold text-4xl sm:text-5xl text-ht-text leading-tight mb-4">SL-15 Lower Kit</h2>
        <p class="text-ht-muted text-base leading-relaxed mb-6">
          Everything you need to build the SL-15 lower. Sourced hardware, documented assembly, no proprietary tools required. The design file is always free to download separately.
        </p>
        <div class="flex items-baseline gap-3 mb-8">
          <span class="text-ht-text font-bold text-3xl">$89.00</span>
          <span class="text-ht-muted text-sm">Free design download available</span>
        </div>
        <div class="flex flex-wrap gap-3">
          <button class="btn-primary">Add to Cart</button>
          <a href="/files" class="btn-ghost">Free Design Files</a>
        </div>
      </div>
    </div>
  </section>

  <!-- PRODUCTS GRID -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 border-t border-ht-border">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p class="section-label mb-2">Kits and Parts</p>
        <h2 class="font-dm font-extrabold text-3xl sm:text-4xl text-ht-text">Support development.</h2>
        <p class="text-ht-muted text-base mt-1">Source hardware yourself or buy a convenience kit.</p>
      </div>
      <a href="/shop" class="hidden sm:block text-ht-accent hover:text-ht-accent-hover text-xs font-bold uppercase tracking-widest transition-colors duration-200">View All &rarr;</a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {products.map((product) => (
        <a href={product.href} class="card group block">
          <div class="overflow-hidden aspect-square bg-ht-surface">
            <img
              src={product.img}
              alt={product.name}
              class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-5">
            <h3 class="font-dm font-bold text-ht-text text-base mb-1">{product.name}</h3>
            <p class="text-ht-accent font-bold text-lg mb-4">{product.price}</p>
            <span class="btn-primary w-full text-center block text-xs">Add to Cart</span>
          </div>
        </a>
      ))}
    </div>

    <div class="mt-8 text-center sm:hidden">
      <a href="/shop" class="btn-ghost">View All Products</a>
    </div>
  </section>

  <!-- SECTION NAV TILES -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 border-t border-ht-border">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {tiles.map((tile) => (
        <a
          href={tile.href}
          class="group block relative overflow-hidden h-56 border border-ht-border hover:border-ht-accent/40 transition-colors duration-200"
        >
          <div class="absolute inset-0">
            <img
              src={tile.img}
              alt={tile.label}
              class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#1a1a1a]/95 via-[#1a1a1a]/40 to-transparent"></div>
          </div>
          <div class="relative h-full flex flex-col justify-end p-5">
            {tile.badge && (
              <span class="inline-block text-ht-accent text-[10px] font-bold uppercase tracking-widest mb-1.5">{tile.badge}</span>
            )}
            <h3 class="font-dm font-extrabold text-ht-text text-2xl uppercase tracking-widest mb-1">{tile.label}</h3>
            <p class="text-ht-muted/80 text-xs">{tile.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- MISSION STRIP -->
  <section class="bg-[#1a1714] border-y border-ht-border py-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <p class="section-label mb-5">Our Mission</p>
      <p class="text-ht-text text-xl sm:text-2xl font-medium leading-relaxed">
        Our goal is to design weapon systems you can 3D print with low cost and accessible equipment.
        The designs are always free and available for anyone to use.
        Decentralized manufacturing for a hitherto centralized industry.
      </p>
      <p class="text-ht-muted text-base mt-6 leading-relaxed">
        Design development is supported when you purchase build kits from us.
        Kits are a convenience, never a requirement.
        To maintain the decentralized model, parts can always be sourced elsewhere.
      </p>
    </div>
  </section>

</Layout>

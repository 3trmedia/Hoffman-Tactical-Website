---
import Layout from '../layouts/Layout.astro';

const featuredDesign = {
  name: 'SL-15',
  description: 'Full lower receiver for AR-15 pattern rifles. Printable on any FDM machine with a 200x200mm bed. Designed for widely available hardware. Documented assembly with no proprietary tools.',
};

const designs = [
  { name: 'SL-9', desc: '9mm AR-pattern lower receiver. Compatible with Glock-style magazines.' },
  { name: 'SL-308', desc: 'Large frame lower for .308/7.62 NATO. Extended hardware spec included.' },
  { name: 'ORCA-15', desc: 'Pistol lower variant with integrated grip geometry. Compact and printable.' },
  { name: 'Stock System', desc: 'Modular buffer tube compatible stock adapter and fixed stock option.' },
  { name: 'Grip System', desc: 'Drop-in pistol grip replacement with improved ergonomics and print orientation.' },
  { name: 'Hose Clamp Cover', desc: 'Decorative and functional barrel nut cover using off-the-shelf hose clamps.' },
  { name: 'SL15-DR', desc: 'Dual-rail lower variant. Extended picatinny interface at the trigger guard.' },
  { name: 'Super Safety', desc: 'Oversized ambidextrous safety selector compatible with standard AR-15 lowers.' },
];
---

<Layout title="Designs -- Hoffman Tactical" description="All released designs are free to download. Click any design for documentation and file links.">

  <!-- PAGE HEADER -->
  <div class="border-b border-ht-border bg-ht-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
      <p class="section-label mb-3">Free Downloads</p>
      <h1 class="font-dm font-extrabold text-5xl sm:text-6xl text-ht-text mb-4">Designs</h1>
      <p class="text-ht-muted text-lg max-w-xl">All released designs are free to download. Click any design for documentation and file links.</p>
    </div>
  </div>

  <!-- FEATURED DESIGN -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="card p-0 overflow-hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2">
        <!-- Render image -->
        <div class="placeholder-img h-72 lg:h-auto min-h-72">
          <span class="placeholder-label">[SL-15 Render]</span>
        </div>

        <!-- Info -->
        <div class="p-8 lg:p-12 flex flex-col justify-center">
          <div class="flex items-center gap-3 mb-4">
            <p class="section-label">Featured Design</p>
            <span class="free-badge">FREE</span>
          </div>
          <h2 class="font-dm font-extrabold text-4xl sm:text-5xl text-ht-text mb-4">{featuredDesign.name}</h2>
          <p class="text-ht-muted text-base leading-relaxed mb-8">{featuredDesign.description}</p>
          <div>
            <a href="#" class="btn-ghost">Download Files</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DESIGN GRID -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-24">
    <h2 class="font-dm font-extrabold text-2xl text-ht-text mb-8">All Designs</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {designs.map((design) => (
        <div class="card group">
          <div class="placeholder-img h-48">
            <span class="placeholder-label">[{design.name} Render]</span>
          </div>
          <div class="p-5">
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-dm font-bold text-ht-text text-lg">{design.name}</h3>
              <span class="free-badge">FREE</span>
            </div>
            <p class="text-ht-muted text-sm leading-relaxed mb-4">{design.desc}</p>
            <a href="#" class="btn-ghost w-full text-center block">View Design</a>
          </div>
        </div>
      ))}
    </div>
  </section>

</Layout>

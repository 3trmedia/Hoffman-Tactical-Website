---
import Layout from '../layouts/Layout.astro';

const BASE = 'https://hoffmantactical.com/wp-content/uploads';

const tiles = [
  {
    label: 'How',
    desc: 'Overview of the build process from start to finish.',
    href: 'https://hoffmantactical.com/learn/',
    img: `${BASE}/2023/11/SL-15-Lower-with-PSA-Upper-On-Post.jpg`,
  },
  {
    label: 'Printers',
    desc: 'Recommended printers and minimum specs for lowers.',
    href: 'https://hoffmantactical.com/learn/',
    img: `${BASE}/2023/12/IMG_7628.jpg`,
  },
  {
    label: 'Filament',
    desc: 'Material selection, brands, and print profiles.',
    href: 'https://hoffmantactical.com/learn/',
    img: `${BASE}/2023/12/Drying-Nylon_0019-scaled.jpg`,
  },
  {
    label: 'Q and A',
    desc: 'Common questions answered from the community.',
    href: 'https://hoffmantactical.com/learn/',
    img: `${BASE}/2023/11/Split-Lower.jpg`,
  },
  {
    label: 'Designs',
    desc: 'Browse and download all released design files.',
    href: '/designs',
    img: `${BASE}/2024/04/Rendering-scaled.jpg`,
  },
  {
    label: 'Articles',
    desc: 'Long-form guides, build logs, and breakdowns.',
    href: '/articles',
    img: `${BASE}/2025/03/Ounce-inside-scaled.jpg`,
  },
  {
    label: 'History',
    desc: 'How Hoffman Tactical started and where it is headed.',
    href: 'https://hoffmantactical.com/learn/',
    img: `${BASE}/2023/11/KF-5-On-Fence.jpg`,
  },
  {
    label: 'Forum',
    desc: 'Community build threads and project discussion.',
    href: 'https://forum.hoffmantactical.com',
    img: `${BASE}/2025/03/Forum-Home_framed.jpg`,
  },
  {
    label: 'Contact',
    desc: 'Reach out with a specific build question.',
    href: '/contact',
    img: `${BASE}/2024/09/AR9-PRO-Left-scaled.jpg`,
  },
];
---

<Layout title="Learn -- Hoffman Tactical" description="Guides and information for building your own weapon systems. 3D printing, assembly, sourcing, and more.">

  <!-- PAGE HEADER -->
  <div class="relative overflow-hidden border-b border-ht-border">
    <div class="absolute inset-0">
      <img src="https://hoffmantactical.com/wp-content/uploads/2025/03/Creep-Test-in-Progress.jpg" alt="" class="w-full h-full object-cover object-center opacity-20" />
      <div class="absolute inset-0 bg-gradient-to-b from-ht-bg/60 to-ht-bg"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
      <p class="section-label mb-3">Resources</p>
      <h1 class="font-dm font-extrabold text-5xl sm:text-6xl text-ht-text mb-4">Learn</h1>
      <p class="text-ht-muted text-lg max-w-xl">Guides and information for building your own weapon systems. 3D printing, assembly, sourcing, and more.</p>
    </div>
  </div>

  <!-- TILE GRID -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tiles.map((tile) => (
        <a
          href={tile.href}
          target={tile.href.startsWith('http') ? '_blank' : undefined}
          rel={tile.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="group block relative overflow-hidden h-52 border border-ht-border hover:border-ht-accent/40 transition-colors duration-200"
        >
          <div class="absolute inset-0">
            <img
              src={tile.img}
              alt={tile.label}
              class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#141414]/95 via-[#141414]/50 to-transparent"></div>
          </div>
          <div class="relative h-full flex flex-col justify-end p-6">
            <h3 class="font-dm font-extrabold text-ht-text text-xl uppercase tracking-widest mb-1 group-hover:text-ht-accent transition-colors duration-200">
              {tile.label}
            </h3>
            <p class="text-ht-muted/80 text-xs">{tile.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

</Layout>
